# TMDB v4 Read Access Token (themoviedb.org → Settings → API)
TMDB_API_KEY=

# Elasticsearch endpoint (defaults to localhost)
ES_URL=http://localhost:9200

# Target index name (must match the mapping created in Part 1)
INDEX=movies

# How many pages of /movie/popular to fetch (each page = 20 movies)
PAGES=5
