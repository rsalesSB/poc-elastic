PUT /movies
{
  "settings": {
    "number_of_shards": 1,
    "number_of_replicas": 0,
    "analysis": {
      "filter": {
        "english_stop": {
          "type": "stop",
          "stopwords": "_english_"
        },
        "english_stemmer": {
          "type": "stemmer",
          "language": "english"
        },
        "english_possessive_stemmer": {
          "type": "stemmer",
          "language": "possessive_english"
        }
      },
      "analyzer": {
        "english_analyzer": {
          "type": "custom",
          "tokenizer": "standard",
          "filter": [
            "english_possessive_stemmer",
            "lowercase",
            "asciifolding",
            "english_stop",
            "english_stemmer"
          ]
        }
      }
    }
  },
  "mappings": {
    "properties": {
      "tmdb_id": {
        "type": "keyword"
      },
      "title": {
        "type": "text",
        "analyzer": "english_analyzer",
        "fields": {
          "keyword": {
            "type": "keyword",
            "ignore_above": 256
          },
          "suggest": {
            "type": "completion"
          }
        }
      },
      "short_description": {
        "type": "text",
        "analyzer": "english_analyzer"
      },
      "content": {
        "type": "text",
        "analyzer": "english_analyzer"
      },
      "genres": {
        "type": "keyword"
      },
      "year": {
        "type": "integer"
      },
      "release_date": {
        "type": "date"
      },
      "popularity": {
        "type": "float"
      },
      "vote_average": {
        "type": "float"
      },
      "poster_url": {
        "type": "keyword",
        "index": false
      }
    }
  }
}
